#!/bin/bash
# ipv6monitor-pf — privileged helper for IPv6Monitor RA protection. See
# docs/superpowers/specs/2026-06-30-pf-ra-protection-app-toggle-design.md
set -u

ANCHOR="com.apple/ipv6monitor"
TABLE="ipv6mon_gw"
STATE_DIR="/var/run/ipv6mon-pf"
SNIFF_SECS="${SNIFF_SECS:-60}"

usage() { echo "Usage: ipv6monitor-pf {detect <iface>|on <iface>|off|status}" >&2; }

valid_iface() {
  local i="${1:-}"
  echo "$i" | grep -qE '^en[0-9]+$' || return 1
  ifconfig "$i" >/dev/null 2>&1 || return 1
  return 0
}

# Reads `tcpdump -vv` RA text on stdin; prints "GW <sources lifetime>0>" then "OTHER <count lifetime 0>".
parse_ra_sources() {
  awk '
    /router advertisement/ { cur=""; for (i=1;i<=NF;i++) if ($i==">") cur=$(i-1) }
    match($0, /router lifetime [0-9]+s/) {
      s=substr($0,RSTART,RLENGTH); gsub(/[^0-9]/,"",s)
      if (cur=="") next
      if (s+0>0) gw[cur]=1; else other[cur]=1
    }
    END {
      printf "GW"
      for (k in gw) printf " %s", k
      printf "\n"
      n=0; for (k in other) if (!(k in gw)) n++
      printf "OTHER %d\n", n
    }
  '
}

# build_rules <iface> <gw1> [gw2 …] — prints the three-line pf ruleset.
build_rules() {
  local iface="$1"; shift
  local list; list=$(printf '%s, ' "$@"); list="${list%, }"
  echo "table <$TABLE> const { $list }"
  echo "pass  in log quick on $iface inet6 proto icmp6 from <$TABLE> to any icmp6-type 134 code 0 no state label \"ipv6mon:pass-ra-gw\""
  echo "block in log quick on $iface inet6 proto icmp6 from fe80::/10 to any icmp6-type 134 code 0 label \"ipv6mon:block-ra-other\""
}

# path_is_safe <path> — 0 only if the path and every parent are uid-0-owned and not
# group/other writable. Guards the sudoers target against local root escalation.
path_is_safe() {
  local p; p=$(cd "$(dirname "$1")" 2>/dev/null && echo "$(pwd)/$(basename "$1")") || return 1
  while : ; do
    local uid perm
    uid=$(stat -f '%u' "$p" 2>/dev/null) || return 1
    perm=$(stat -f '%Lp' "$p" 2>/dev/null) || return 1
    [ "$uid" = "0" ] || return 1
    case "$perm" in *[2367]) return 1 ;; esac          # other-writable (last octal digit)
    local g="${perm%?}"; g="${g#"${g%?}"}"             # group (second-from-last) digit
    case "$g" in 2|3|6|7) return 1 ;; esac             # group-writable
    [ "$p" = "/" ] && break
    p=$(dirname "$p")
  done
  return 0
}

# Reads `pfctl -a <anchor> -s labels` on stdin; prints "PASS <n> BLOCK <n>" (col 4 = total packets).
parse_labels() {
  awk '
    /^ipv6mon:pass-ra-gw/     { pass=$3 }
    /^ipv6mon:block-ra-other/ { block=$3 }
    END { printf "PASS %d BLOCK %d\n", pass+0, block+0 }
  '
}

json_status() { # active iface pass block default_route
  printf '{"active":%s,"iface":"%s","pass":%d,"block":%d,"default_route":%s}\n' \
    "$1" "$2" "$3" "$4" "$5"
}

require_root() { [ "$(id -u)" -eq 0 ] || { echo '{"error":"must run as root"}'; exit 1; }; }

# Sniff RAs on <iface> for SNIFF_SECS, print raw tcpdump -vv text on stdout.
sniff_ras() {
  local iface="$1" tmp td
  tmp=$(mktemp)
  tcpdump -ni "$iface" -vv -l 'icmp6 and ip6[40] == 134' >"$tmp" 2>/dev/null &
  td=$!
  sleep "$SNIFF_SECS"
  kill "$td" 2>/dev/null; wait "$td" 2>/dev/null
  cat "$tmp"; rm -f "$tmp"
}

# JSON array from a space-separated address list.
json_array() {
  local out="" a
  for a in $1; do out="$out\"$a\","; done
  printf '[%s]' "${out%,}"
}

rollback() {
  pfctl -a "$ANCHOR" -F rules  >/dev/null 2>&1
  pfctl -a "$ANCHOR" -F Tables >/dev/null 2>&1
  if [ -f "$STATE_DIR/token" ]; then
    pfctl -X "$(cat "$STATE_DIR/token")" >/dev/null 2>&1
    rm -f "$STATE_DIR/token"
  fi
}

# Ensure the stock com.apple/* wildcard anchor is active so our sub-anchor is evaluated.
ensure_anchor_available() {
  if pfctl -s info 2>/dev/null | grep -q "Status: Enabled"; then
    pfctl -sr 2>/dev/null | grep -q 'anchor "com.apple/\*"' && return 0
    echo '{"error":"pf enabled with a custom ruleset (no com.apple/* anchor); refusing"}'
    return 1
  fi
  pfctl -f /etc/pf.conf >/dev/null 2>&1
  local tok; tok=$(pfctl -E 2>&1 | awk '/Token/{print $NF}')
  [ -n "$tok" ] && echo "$tok" > "$STATE_DIR/token"
  pfctl -sr 2>/dev/null | grep -q 'anchor "com.apple/\*"' || {
    echo '{"error":"com.apple/* anchor absent after loading stock pf.conf"}'; rollback; return 1; }
  return 0
}

cmd_detect() {
  local iface="${1:-}"
  valid_iface "$iface" || { echo '{"error":"invalid interface"}'; exit 2; }
  local parsed gws others
  parsed=$(sniff_ras "$iface" | parse_ra_sources)
  gws=$(echo "$parsed" | sed -n '1p' | sed 's/^GW //; s/^GW$//')
  others=$(echo "$parsed" | sed -n '2p' | awk '{print $2}')
  printf '{"gateways":%s,"others":%d}\n' "$(json_array "$gws")" "${others:-0}"
}

cmd_on() {
  require_root
  local iface="${1:-}"
  valid_iface "$iface" || { echo '{"error":"invalid interface"}'; exit 2; }
  mkdir -p "$STATE_DIR"
  local parsed gws
  parsed=$(sniff_ras "$iface" | parse_ra_sources)
  gws=$(echo "$parsed" | sed -n '1p' | sed 's/^GW //; s/^GW$//')
  [ -n "$gws" ] || { echo '{"error":"no gateway (positive-lifetime RA) seen"}'; exit 1; }
  local rules; rules=$(build_rules "$iface" $gws)
  ensure_anchor_available || exit 1
  trap 'rollback; echo "{\"error\":\"aborted\"}"; exit 1' ERR INT
  echo "$rules" | pfctl -n -a "$ANCHOR" -f - 2>/dev/null || {
    rollback; echo '{"error":"rule parse failed"}'; exit 1; }
  echo "$rules" | pfctl -a "$ANCHOR" -f - 2>/dev/null
  trap - ERR INT
  echo "$iface" > "$STATE_DIR/iface"
  date +%s > "$STATE_DIR/start"
  cmd_status
}

cmd_off() {
  require_root
  rollback
  rm -f "$STATE_DIR/iface" "$STATE_DIR/start"
  echo '{"active":false}'
}

cmd_status() {
  local active=false iface="" pass=0 block=0 route=false labels
  if pfctl -a "$ANCHOR" -sr 2>/dev/null | grep -q 'ipv6mon:'; then active=true; fi
  labels=$(pfctl -a "$ANCHOR" -s labels 2>/dev/null | parse_labels)
  pass=$(echo "$labels" | awk '{print $2}'); block=$(echo "$labels" | awk '{print $4}')
  [ -f "$STATE_DIR/iface" ] && iface=$(cat "$STATE_DIR/iface")
  route -n get -inet6 default >/dev/null 2>&1 && route=true
  json_status "$active" "$iface" "${pass:-0}" "${block:-0}" "$route"
}

_main() {
  cmd="${1:-}"; [ $# -gt 0 ] && shift
  case "$cmd" in
    detect) cmd_detect "$@" ;;
    on)     cmd_on "$@" ;;
    off)    cmd_off "$@" ;;
    status) cmd_status "$@" ;;
    *) usage; exit 2 ;;
  esac
}

# Run dispatch only when executed, not when sourced (for tests).
if [ "${BASH_SOURCE[0]}" = "$0" ]; then _main "$@"; fi
